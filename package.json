{
  "name": "devops-task-manager",
  "version": "1.0.0",
  "description": "A simple Task Manager app demonstrating a full CI/CD pipeline with GitHub Actions and Render.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["devops", "ci-cd", "github-actions", "express", "nodejs"],
  "author": "Your Name",
  "license": "MIT"
}
